      <operator activated="true" class="blending:generate_columns" compatibility="12.0.005" expanded="true" height="82" name="Generate Threshold Metrics" width="90" x="2859" y="442">
        <list key="function_descriptions">
          <parameter key="accuracy" value="(tp + tn) / n"/>
          <parameter key="risk_precision" value="if(tp + fp == 0, 0, tp / (tp + fp))"/>
          <parameter key="risk_recall" value="if(tp + fn == 0, 0, tp / (tp + fn))"/>
          <parameter key="norisk_precision" value="if(tn + fn == 0, 0, tn / (tn + fn))"/>
          <parameter key="norisk_recall" value="if(tn + fp == 0, 0, tn / (tn + fp))"/>
          <parameter key="sort_key" value="(tp + tn) * 1000000 + tn * 1000 + threshold"/>
        </list>
        <parameter key="keep_all_columns" value="true"/>
        <parameter key="default_time_zone" value="Asia/Saigon"/>
      </operator>
