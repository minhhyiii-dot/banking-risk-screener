      <operator activated="true" class="blending:generate_columns" compatibility="12.0.005" expanded="true" height="82" name="Generate Threshold Flag" width="90" x="2457" y="442">
        <list key="function_descriptions">
          <parameter key="prediction_tmp" value="if(ensemble_probability &gt;= threshold, &quot;Risk&quot;, &quot;NoRisk&quot;)"/>
          <parameter key="tp_flag" value="if(risk10_label == &quot;Risk&quot;, if(prediction_tmp == &quot;Risk&quot;, 1, 0), 0)"/>
          <parameter key="fp_flag" value="if(risk10_label == &quot;NoRisk&quot;, if(prediction_tmp == &quot;Risk&quot;, 1, 0), 0)"/>
          <parameter key="fn_flag" value="if(risk10_label == &quot;Risk&quot;, if(prediction_tmp == &quot;NoRisk&quot;, 1, 0), 0)"/>
          <parameter key="tn_flag" value="if(risk10_label == &quot;NoRisk&quot;, if(prediction_tmp == &quot;NoRisk&quot;, 1, 0), 0)"/>
          <parameter key="n_flag" value="1"/>
        </list>
        <parameter key="keep_all_columns" value="true"/>
        <parameter key="default_time_zone" value="Asia/Saigon"/>
      </operator>
